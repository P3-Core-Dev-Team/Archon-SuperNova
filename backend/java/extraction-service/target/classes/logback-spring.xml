<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">
    <springProperty name="LOG_FILE_PATH" source="logging.file.path" defaultValue="/var/log/discovery"/>
    <springProperty name="LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>
    <springProperty name="APP_LOG_LEVEL" source="logging.level.com.discovery.extraction" defaultValue="INFO"/>

    <!-- CONSOLE appender with JSON encoder for structured logging -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Include standard fields -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <includeMdc>true</includeMdc>
            <includeThreadName>true</includeThreadName>
            <includeContext>true</includeContext>
            <!-- Custom fields for tracing -->
            <customFields>{"service":"discovery-extraction-service","version":"1.0.0"}</customFields>
        </encoder>
    </appender>

    <!-- AUDIT appender for audit log (separate rolling file) -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE_PATH}/audit.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <includeMdc>true</includeMdc>
            <customFields>{"audit":true,"service":"discovery-extraction-service"}</customFields>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE_PATH}/audit.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Root logger: INFO level to console JSON -->
    <root level="${LOG_LEVEL}">
        <appender-ref ref="CONSOLE_JSON"/>
    </root>

    <!-- Application logger: configurable level (DEBUG in dev) -->
    <logger name="com.discovery.extraction" level="${APP_LOG_LEVEL}"/>

    <!-- Audit logger: separate channel, no additivity to root -->
    <logger name="com.discovery.extraction.audit" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE"/>
    </logger>

    <!-- Spring Framework logging level -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.boot" level="INFO"/>

    <!-- Resilience4j and other frameworks -->
    <logger name="io.github.resilience4j" level="INFO"/>

    <!-- Dev profile: enable verbose logging for Spring components -->
    <springProfile name="dev">
        <logger name="org.springframework.boot.autoconfigure" level="DEBUG"/>
        <logger name="org.springframework.boot.context.embedded" level="DEBUG"/>
    </springProfile>

    <!--
    NOTE: Password redaction is handled in application code via:
    - Jackson mixins to exclude sensitive fields from serialization
    - Connection credential references via environment variables (never logged)

    The audit logger writes one structured event per accepted extraction
    request via AuditLogger#recordAccepted(). Raw query text is never
    logged; only a SHA-256 hash + length appear in the audit channel.
    -->

</configuration>
